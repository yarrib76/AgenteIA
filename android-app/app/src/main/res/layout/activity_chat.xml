<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="#EFEAE2">

  <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    android:id="@+id/chatRefresh"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1">

    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/chatRecycler"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:clipToPadding="false"
      android:paddingTop="10dp"
      android:paddingBottom="10dp"
      app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
  </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

  <TextView
    android:id="@+id/chatStatusText"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingTop="4dp"
    android:textColor="@android:color/holo_red_dark" />

  <HorizontalScrollView
    android:id="@+id/chatEmojiScroll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#DDE7E3"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp"
    android:visibility="gone"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
      android:id="@+id/chatEmojiBar"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal">

      <TextView android:id="@+id/emojiSmile" style="@style/EmojiButton">😀</TextView>
      <TextView android:id="@+id/emojiLaugh" style="@style/EmojiButton">😂</TextView>
      <TextView android:id="@+id/emojiHeart" style="@style/EmojiButton">❤️</TextView>
      <TextView android:id="@+id/emojiThumbs" style="@style/EmojiButton">👍</TextView>
      <TextView android:id="@+id/emojiRobot" style="@style/EmojiButton">🤖</TextView>
      <TextView android:id="@+id/emojiFire" style="@style/EmojiButton">🔥</TextView>
      <TextView android:id="@+id/emojiCheck" style="@style/EmojiButton">✅</TextView>
      <TextView android:id="@+id/emojiParty" style="@style/EmojiButton">🎉</TextView>
    </LinearLayout>
  </HorizontalScrollView>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F6F1E8"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageButton
      android:id="@+id/chatEmojiButton"
      android:layout_width="44dp"
      android:layout_height="44dp"
      android:background="@drawable/bg_icon_button"
      android:contentDescription="emoji"
      android:src="@drawable/ic_emoji" />

    <EditText
      android:id="@+id/chatInput"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginStart="8dp"
      android:layout_marginEnd="8dp"
      android:background="@drawable/bg_chat_input"
      android:hint="@string/message_hint"
      android:maxLines="5"
      android:minHeight="44dp"
      android:paddingHorizontal="14dp"
      android:paddingVertical="10dp" />

    <ImageButton
      android:id="@+id/chatSendButton"
      android:layout_width="46dp"
      android:layout_height="46dp"
      android:background="@drawable/bg_send_button"
      android:contentDescription="send"
      android:src="@drawable/ic_send" />
  </LinearLayout>

</LinearLayout>

