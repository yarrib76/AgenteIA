<% const view = typeof authData !== 'undefined' ? authData : { currentUser, error, name, email, next, success, challenge, users }; %>
<div class="auth-card">
  <div>
    <p class="auth-eyebrow"><%= view.currentUser ? 'Usuarios' : 'Onboarding' %></p>
    <h2 class="auth-title"><%= view.currentUser ? 'Crear nuevo usuario' : 'Crear primer usuario' %></h2>
    <p class="auth-copy">El nombre ayuda a identificar a la persona dentro del sistema. El email sigue siendo el identificador de acceso.</p>
  </div>

  <% if (view.error) { %>
    <div class="auth-alert auth-alert-error"><%= view.error %></div>
  <% } %>

  <% if (view.success) { %>
    <div class="auth-alert auth-alert-success"><%= view.success %></div>
  <% } %>

  <form class="auth-form" method="post" action="/register">
    <input type="hidden" name="next" value="<%= view.next %>" />
    <label class="field">
      <span>Nombre</span>
      <input type="text" name="name" value="<%= view.name || '' %>" autocomplete="name" />
    </label>
    <label class="field">
      <span>Email</span>
      <input type="email" name="email" value="<%= view.email %>" autocomplete="email" required />
    </label>
    <label class="field">
      <span>Contraseña</span>
      <input type="password" name="password" autocomplete="new-password" required />
      <small class="field-hint">Mínimo 8 caracteres, con mayúsculas, minúsculas y números.</small>
    </label>
    <label class="field">
      <span>Confirmar contraseña</span>
      <input type="password" name="confirmPassword" autocomplete="new-password" required />
    </label>
    <label class="field">
      <span>Captcha: resolvé <strong><%= view.challenge.prompt %></strong></span>
      <input type="text" name="captchaAnswer" inputmode="numeric" required />
    </label>
    <button class="primary-button auth-submit" type="submit">Crear usuario</button>
  </form>

  <% if (view.currentUser) { %>
    <div class="card module-card mt-16">
      <div class="card-header">
        <h3>Usuarios existentes</h3>
      </div>
      <% if (!view.users || view.users.length === 0) { %>
        <p class="note">No hay usuarios creados.</p>
      <% } else { %>
        <div class="stack-list">
          <% view.users.forEach(function(user) { %>
          <form method="post" action="/usuarios/<%= user.id %>/actualizar" class="card module-card mb-12">
            <div class="form-grid">
              <label class="field">
                <span>Nombre</span>
                <input type="text" name="name" value="<%= user.name || '' %>" placeholder="Sin nombre" />
              </label>
              <label class="field">
                <span>Email</span>
                <input type="email" name="email" value="<%= user.email %>" required />
              </label>
              <label class="field">
                <span>Nueva contraseña</span>
                <input type="password" name="password" placeholder="Opcional" />
                <small class="field-hint">Dejá vacío para no cambiarla.</small>
              </label>
              <div class="field">
                <span>Alta</span>
                <div class="note"><%= user.createdAt || '-' %></div>
              </div>
            </div>
            <div class="inline-actions mt-8">
              <button class="secondary-button" type="submit">Guardar cambios</button>
            </div>
          </form>
          <form method="post" action="/usuarios/<%= user.id %>/eliminar" class="inline-actions mb-16" onsubmit="return confirm('¿Eliminar este usuario?');">
            <button class="danger-button" type="submit">Eliminar</button>
          </form>
          <% }) %>
        </div>
      <% } %>
    </div>
  <% } %>

  <div class="auth-footer-links">
    <% if (view.currentUser) { %>
      <a href="/whatsapp">Volver al panel</a>
    <% } else { %>
      <a href="/login">Ya tengo usuario</a>
    <% } %>
  </div>
</div>
