<% const view = typeof authData !== 'undefined' ? authData : { currentUser, error, name, email, next, success, challenge, users }; %>
<% function formatUserDate(value) { %>
<%   if (!value) { %>
<%     return '-'; %>
<%   } %>
<%   const parsed = new Date(value); %>
<%   if (Number.isNaN(parsed.getTime())) { %>
<%     return value; %>
<%   } %>
<%   return parsed.toLocaleString('es-AR'); %>
<% } %>
<% if (view.currentUser) { %>
<div class="card module-card">
  <div class="card-header">
    <h2 id="usersFormTitle">Nuevo usuario</h2>
  </div>

  <% if (view.error) { %>
    <div class="auth-alert auth-alert-error"><%= view.error %></div>
  <% } %>

  <% if (view.success) { %>
    <div class="auth-alert auth-alert-success"><%= view.success %></div>
  <% } %>

  <p id="usersFormCopy" class="note">El nombre ayuda a identificar a la persona dentro del sistema. El email sigue siendo el identificador de acceso.</p>

  <form id="userForm" class="form-grid" method="post" action="/register">
    <input type="hidden" name="next" value="<%= view.next %>" />
    <input type="hidden" id="userFormMode" value="create" />

    <label class="field">
      <span>Nombre</span>
      <input id="userNameInput" type="text" name="name" value="<%= view.name || '' %>" autocomplete="name" />
    </label>

    <label class="field">
      <span>Email</span>
      <input id="userEmailInput" type="email" name="email" value="<%= view.email %>" autocomplete="email" required />
    </label>

    <label class="field">
      <span id="userPasswordLabel">Contraseña</span>
      <input id="userPasswordInput" type="password" name="password" autocomplete="new-password" required />
      <small id="userPasswordHint" class="field-hint">Mínimo 8 caracteres, con mayúsculas, minúsculas y números.</small>
    </label>

    <label class="field">
      <span id="userConfirmPasswordLabel">Confirmar contraseña</span>
      <input id="userConfirmPasswordInput" type="password" name="confirmPassword" autocomplete="new-password" required />
    </label>

    <label id="captchaField" class="field">
      <span>Captcha: resolvé <strong><%= view.challenge.prompt %></strong></span>
      <input id="captchaInput" type="text" name="captchaAnswer" inputmode="numeric" required />
    </label>

    <div class="modal-actions">
      <button id="cancelUserEditBtn" class="secondary-button hidden" type="button">Cancelar edición</button>
      <button id="userSubmitBtn" class="primary-button" type="submit">Crear usuario</button>
    </div>
  </form>
</div>

<div class="card module-card mt-16">
  <div class="card-header">
    <h2>Usuarios registrados</h2>
  </div>

  <% if (!view.users || view.users.length === 0) { %>
  <p class="note">No hay usuarios creados.</p>
  <% } else { %>
  <table class="table" id="usersTable">
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Email</th>
        <th>Alta</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% view.users.forEach(function(user) { %>
      <tr>
        <td data-col="nombre"><%= user.name || '-' %></td>
        <td data-col="email" class="wrap-cell"><%= user.email %></td>
        <td data-col="alta"><%= formatUserDate(user.createdAt) %></td>
        <td data-col="acciones">
          <div class="inline-actions">
            <button
              class="secondary-button edit-user-btn"
              type="button"
              data-user-id="<%= user.id %>"
              data-user-name="<%= user.name || '' %>"
              data-user-email="<%= user.email %>"
            >
              Modificar
            </button>
            <form method="post" action="/usuarios/<%= user.id %>/eliminar" onsubmit="return confirm('¿Eliminar este usuario?');">
              <button class="secondary-button danger-button" type="submit">Eliminar</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<% } else { %>
<div class="auth-card">
  <div>
    <p class="auth-eyebrow">Onboarding</p>
    <h2 class="auth-title">Crear primer usuario</h2>
    <p class="auth-copy">El nombre ayuda a identificar a la persona dentro del sistema. El email sigue siendo el identificador de acceso.</p>
  </div>

  <% if (view.error) { %>
    <div class="auth-alert auth-alert-error"><%= view.error %></div>
  <% } %>

  <% if (view.success) { %>
    <div class="auth-alert auth-alert-success"><%= view.success %></div>
  <% } %>

  <form class="auth-form" method="post" action="/register">
    <input type="hidden" name="next" value="<%= view.next %>" />
    <label class="field">
      <span>Nombre</span>
      <input type="text" name="name" value="<%= view.name || '' %>" autocomplete="name" />
    </label>
    <label class="field">
      <span>Email</span>
      <input type="email" name="email" value="<%= view.email %>" autocomplete="email" required />
    </label>
    <label class="field">
      <span>Contraseña</span>
      <input type="password" name="password" autocomplete="new-password" required />
      <small class="field-hint">Mínimo 8 caracteres, con mayúsculas, minúsculas y números.</small>
    </label>
    <label class="field">
      <span>Confirmar contraseña</span>
      <input type="password" name="confirmPassword" autocomplete="new-password" required />
    </label>
    <label class="field">
      <span>Captcha: resolvé <strong><%= view.challenge.prompt %></strong></span>
      <input type="text" name="captchaAnswer" inputmode="numeric" required />
    </label>
    <button class="primary-button auth-submit" type="submit">Crear usuario</button>
  </form>

  <div class="auth-footer-links">
    <a href="/login">Ya tengo usuario</a>
  </div>
</div>
<% } %>
