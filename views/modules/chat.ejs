<div class="card module-card">
  <div class="card-header">
    <h2>Conversaciones</h2>
  </div>

  <div class="chat-toolbar">
    <% if (activeChannel === "internal_chat") { %>
    <label class="field">
      <span>Modo</span>
      <select id="internalActorModeSelect">
        <option value="user" <%= internalActorMode === "user" ? "selected" : "" %>>Ver como usuario</option>
        <option value="system" <%= internalActorMode === "system" ? "selected" : "" %>>Ver mensajes del Sistema</option>
      </select>
    </label>
    <% } %>

    <label class="field">
      <span><%= activeChannel === "internal_chat" ? "Destino interno" : "Contacto" %></span>
      <select id="contactSelect">
        <option value="">Seleccionar...</option>
        <% contacts.forEach(function(contact) { %>
        <option value="<%= contact.id %>" <%= selectedContactId === contact.id ? "selected" : "" %>>
          <% if (activeChannel === "internal_chat") { %>
            <%= contact.name %> [<%= contact.type === "group" ? "Grupo" : "Usuario" %>]
          <% } else { %>
            <%= contact.name %> [<%= contact.type === "group" ? "Grupo" : "Usuario" %>] (<%= activeChannel === "telegram" ? (contact.type === "group" ? (contact.telegramGroupId || "-") : (contact.telegramUserId || "-")) : (contact.type === "group" ? (contact.groupId || contact.whatsappId || "-") : contact.phone) %>)
          <% } %>
        </option>
        <% }) %>
      </select>
    </label>

    <button id="clearHistoryBtn" class="secondary-button danger-button" type="button">
      Borrar historial
    </button>
  </div>

  <div id="chatStatus" class="note">
    <% if (channelReady) { %>
      <%= activeChannel === "telegram" ? "Telegram activo." : activeChannel === "internal_chat" ? "Chat interno activo." : "WhatsApp vinculado." %>
    <% } else { %>
      <%= activeChannel === "telegram" ? "Telegram no configurado." : activeChannel === "internal_chat" ? "Chat interno no disponible." : "WhatsApp no vinculado." %>
    <% } %>
    <% if (!selectedContactConfigured) { %> El contacto seleccionado no esta configurado para este canal. <% } %>
  </div>

  <div id="chatWindow" class="chat-window">
    <% if (!messages || messages.length === 0) { %>
    <p class="note">Sin mensajes recientes para este contacto.</p>
    <% } else { %>
    <% messages.forEach(function(msg) { %>
    <div class="message <%= msg.direction === 'out' ? 'out' : 'in' %>">
      <div class="bubble">
        <% if (activeChannel === 'internal_chat' && msg.direction !== 'out' && msg.conversationType === 'group' && msg.senderName) { %>
        <div class="meta"><strong><%= msg.senderName %></strong></div>
        <% } %>
        <% if (msg.attachment && msg.attachment.type === 'image' && msg.attachment.url) { %>
        <img
          class="chat-image"
          src="<%= msg.attachment.url %>"
          data-fallback-src="<%= msg.attachment.fallbackUrl || '' %>"
          onerror="if(this.dataset.fallbackSrc && this.src.indexOf(this.dataset.fallbackSrc)===-1){this.src=this.dataset.fallbackSrc;}else{this.style.display='none';}"
          alt="<%= msg.attachment.originalName || 'imagen' %>" />
        <% } %>
        <% if (msg.text) { %>
        <div><%= msg.text %></div>
        <% } %>
      </div>
      <span class="meta"><%= msg.timestampFormatted || msg.timestamp %></span>
    </div>
    <% }) %>
    <% } %>
  </div>

  <form id="chatForm" class="chat-form">
    <input type="hidden" id="activeChannel" value="<%= activeChannel %>" />
    <input type="hidden" id="internalActorMode" value="<%= internalActorMode || 'user' %>" />
    <input type="hidden" id="selectedContactConfigured" value="<%= selectedContactConfigured ? 'true' : 'false' %>" />
    <div class="chat-input-stack">
      <% if (activeChannel === "internal_chat") { %>
      <div id="chatAttachmentPreview" class="chat-attachment-preview hidden">
        <img id="chatAttachmentImage" class="chat-attachment-image" alt="preview" />
        <div class="chat-attachment-meta">
          <strong id="chatAttachmentName"></strong>
          <button id="chatAttachmentClear" class="secondary-button" type="button">Quitar</button>
        </div>
      </div>
      <% } %>
      <div class="chat-form-row <%= activeChannel === 'internal_chat' ? '' : 'no-attachment' %>">
        <% if (activeChannel === "internal_chat") { %>
        <input type="file" id="chatImageInput" accept="image/png,image/jpeg,image/webp" class="hidden" />
        <button id="chatAttachBtn" class="secondary-button" type="button" <%= selectedContactConfigured ? "" : "disabled" %>>Imagen</button>
        <% } %>
        <input type="text" id="chatInput" maxlength="2000" placeholder="Escribe un mensaje..." <%= selectedContactConfigured ? "" : "disabled" %> />
        <button class="primary-button" type="submit" <%= selectedContactConfigured ? "" : "disabled" %>>Enviar</button>
      </div>
    </div>
  </form>
</div>
